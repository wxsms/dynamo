{
  "sandboxID": "aaaabbbbccccddddeeeeffff00001111222233334444555566667777",
  "pid": 54321,
  "runtimeSpec": {
    "ociVersion": "1.0.2-dev",
    "root": {
      "path": "/var/lib/containers/storage/overlay/xyz/merged",
      "readonly": false
    },
    "mounts": [
