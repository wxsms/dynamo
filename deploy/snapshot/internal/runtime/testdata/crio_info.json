      }
    ],
    "linux": {
      "maskedPaths": [
        "/proc/acpi",
        "/proc/kcore",
        "/proc/keys"
      ],
      "readonlyPaths": [
        "/proc/bus",
        "/proc/fs",
        "/proc/irq",
        "/proc/sys"
      ]
