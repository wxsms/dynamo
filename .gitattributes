*.mp4               binary

# Exclude test data files from linguist language detection
lib/llm/tests/data/** linguist-vendored
lib/llm/tests/snapshots/** linguist-vendored

# Preserve the released vLLM proto byte-for-byte, including its trailing blank line.
lib/backend/vllm-sidecar/proto/vllm_grpc.proto -text diff whitespace=-blank-at-eof
