*                   text  eol=lf
*.sln               text  eol=crlf
*.[Ii][Cc][Oo]      binary
*.[Jj][Pp][Ee][Gg]  binary
*.[Jj][Pp][Gg]      binary
*.[Pp][Dd][Ff]      binary
*.[Pp][Nn][Gg]      binary
*.[Ww][Ee][Bb][Pp]  binary
*.[Zz][Ii][Pp]      binary
*.[Tt][Gg][Zz]      binary
*.[Gg][Zz]          binary
