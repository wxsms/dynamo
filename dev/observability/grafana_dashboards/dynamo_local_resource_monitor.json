    {
      "title": "GPU VRAM (GiB) + PCIe (GB/s)",
      "description": "Stacked per-process GPU memory (left axis) with PCIe TX/RX on right axis. PCIe sampled at 10/s by dedicated subprocesses (separate from main loop because nvidia-smi pcie queries are blocking).",
      "datasource": {
        "type": "prometheus",
        "uid": "dynamo-resource-monitor"
      },
      "type": "timeseries",
      "interval": "200ms",
      "maxDataPoints": 5000,
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "GiB",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 85,
            "gradientMode": "none",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "none",
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Total"
            },
            "properties": [
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "#ff5252",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.stacking",
                "value": {
                  "group": "A",
                  "mode": "none"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "solid"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*PCIe TX.*"
            },
            "properties": [
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "rgba(239,83,80,0.6)",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.stacking",
                "value": {
                  "group": "B",
                  "mode": "none"
                }
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.axisLabel",
                "value": "PCIe GB/s"
              },
              {
                "id": "custom.scaleDistribution",
                "value": {
                  "type": "log",
                  "log": 2
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*PCIe RX.*"
            },
            "properties": [
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "rgba(105,240,174,0.6)",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.stacking",
                "value": {
                  "group": "B",
                  "mode": "none"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    4,
                    4
                  ]
                }
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              },
              {
                "id": "custom.axisLabel",
                "value": ""
              },
              {
                "id": "custom.scaleDistribution",
                "value": {
                  "type": "log",
                  "log": 2
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "sortBy": "Last *",
          "sortDesc": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dynamo-resource-monitor"
          },
          "editorMode": "code",
          "expr": "dynamo_gpu_memory_used_gib > 0.1",
          "legendFormat": "{{process_name}} ({{pid}})",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dynamo-resource-monitor"
          },
          "editorMode": "code",
          "expr": "dynamo_gpu_memory_total_gib",
          "legendFormat": "Total",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dynamo-resource-monitor"
          },
          "editorMode": "code",
          "expr": "dynamo_gpu_pcie_tx_gbps",
          "legendFormat": "GPU {{gpu}} PCIe TX",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "dynamo-resource-monitor"
          },
          "editorMode": "code",
          "expr": "dynamo_gpu_pcie_rx_gbps",
          "legendFormat": "GPU {{gpu}} PCIe RX",
          "range": true,
          "refId": "D"
        }
      ]
    },
